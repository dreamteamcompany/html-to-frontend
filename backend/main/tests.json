{
  "tests": [
    {
      "name": "Login Success",
      "method": "POST",
      "path": "/?endpoint=login",
      "body": {"username": "admin", "password": "admin"},
      "expectedStatus": 200
    },
    {
      "name": "Unauthorized Access",
      "method": "GET",
      "path": "/?endpoint=users",
      "expectedStatus": 401
    },
    {
      "name": "Approvers Unauthorized",
      "method": "GET",
      "path": "/?endpoint=approvers",
      "expectedStatus": 401
    },
    {
      "name": "Check Health Options",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Check Health GET",
      "method": "GET",
      "path": "/?endpoint=health",
      "expectedStatus": 200,
      "expectedBody": {"status": "string", "version": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Ticket Dictionaries Unauthorized",
      "method": "GET",
      "path": "/?endpoint=ticket-dictionaries-api",
      "expectedStatus": 401
    },
    {
      "name": "WebAuthn Credentials Unauthorized",
      "method": "GET",
      "path": "/?endpoint=webauthn-credentials",
      "expectedStatus": 401
    },
    {
      "name": "Savings List Unauthorized",
      "method": "GET",
      "path": "/?endpoint=savings-list",
      "expectedStatus": 401
    }
  ]
}